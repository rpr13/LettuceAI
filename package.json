{
  "name": "lettuceai",
  "private": true,
  "version": "1.2.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "sync-version": "node scripts/sync-version.mjs",
    "tauri": "tauri",
    "tauri:dev:webkit-safe": "node scripts/run-tauri-webkit-safe.mjs dev",
    "tauri:build:webkit-safe": "node scripts/run-tauri-webkit-safe.mjs build",
    "tauri:dev:cuda:auto": "node scripts/run-tauri-cuda-auto.mjs dev",
    "tauri:build:cuda:auto": "node scripts/run-tauri-cuda-auto.mjs build",
    "tauri:build:macos": "tauri build --bundles app,dmg -c src-tauri/tauri.macos.conf.json",
    "tauri:dev:metal": "tauri dev --features llama-gpu-metal",
    "tauri:build:metal": "tauri build --features llama-gpu-metal -c src-tauri/tauri.macos.conf.json",
    "android:apply-overrides": "node scripts/apply-android-overrides.mjs",
    "tauri:android:init": "tauri android init && node scripts/apply-android-overrides.mjs",
    "tauri:android:dev": "node scripts/run-tauri-android-local-tmp.mjs dev",
    "tauri:android:build": "node scripts/run-tauri-android-local-tmp.mjs build",
    "tauri:ios:init": "tauri ios init",
    "tauri:ios:dev": "tauri ios dev",
    "tauri:ios:build": "tauri ios build",
    "check": "(tsc --noEmit && cd src-tauri && cargo check) && echo 'All checks successful.' || echo 'Check failed.'"
  },
  "dependencies": {
    "@tailwindcss/vite": "^4.2.2",
    "@tanstack/react-virtual": "^3.13.23",
    "@tauri-apps/api": "^2.10.1",
    "@tauri-apps/plugin-barcode-scanner": "^2.4.4",
    "@tauri-apps/plugin-dialog": "^2.6.0",
    "@tauri-apps/plugin-fs": "^2.4.5",
    "@tauri-apps/plugin-haptics": "^2.3.2",
    "@tauri-apps/plugin-opener": "^2.5.3",
    "@tauri-apps/plugin-os": "^2.3.2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@types/dompurify": "^3.2.0",
    "dompurify": "^3.3.3",
    "framer-motion": "^12.38.0",
    "lucide-react": "^0.577.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "react-markdown": "^10.1.0",
    "react-qr-code": "^2.0.18",
    "react-router-dom": "^7.13.1",
    "recharts": "^3.8.0",
    "rehype-raw": "^7.0.0",
    "remark-gfm": "^4.0.1",
    "sonner": "^2.0.7",
    "tauri-plugin-android-fs-api": "^27.1.0",
    "tauri-plugin-app-events-api": "^0.2.0",
    "tauri-plugin-tts-api": "0.1.3",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "@types/react": "19.2.14",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "prettier": "^3.8.1",
    "tailwindcss": "^4.2.2",
    "typescript": "~5.9.3",
    "vite": "^8.0.1"
  },
  "lint-staged": {
    "src/**/*.{ts,tsx,js,jsx,json,css,md}": [
      "prettier -w",
      "eslint --fix"
    ]
  }
}
